{
  "name": "@smplcty/schema-flow",
  "version": "0.17.0",
  "description": "Declarative PostgreSQL schema management tool",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mabulu-inc/simplicity-schema-flow.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "schema-flow": "./dist/cli/index.js"
  },
  "scripts": {
    "lint": "eslint src/",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm lint && pnpm format && pnpm typecheck && pnpm build && pnpm test:coverage",
    "prepare": "husky",
    "release": "GITHUB_TOKEN=$(gh auth token) release-it",
    "release:patch": "GITHUB_TOKEN=$(gh auth token) release-it patch",
    "release:minor": "GITHUB_TOKEN=$(gh auth token) release-it minor",
    "release:major": "GITHUB_TOKEN=$(gh auth token) release-it major"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "pg": "^8.22.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@release-it/keep-a-changelog": "^7.1.0",
    "@testcontainers/postgresql": "^12.0.3",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.0",
    "release-it": "^20.2.1",
    "testcontainers": "12.0.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
